#compdef git-moat

# Zsh completion for git-moat.
# Install to a directory in $fpath, e.g. ~/.local/share/zsh/site-functions/
#
# To activate immediately without reinstalling:
#   autoload -Uz compinit && compinit

_git-moat() {
  local state

  _arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->subcommand' \
    '*:: :->args'

  case $state in
    subcommand)
      local subcommands
      subcommands=(
        'clone:Clone a repository with threat scanning before opening'
        'checkout:Scan a branch in a temp worktree, then switch if safe'
        'pull:Scan incoming commits on the current branch, then fast-forward if safe'
        'fetch:Passthrough to git fetch (downloads refs, no working-tree changes)'
      )
      _describe 'subcommand' subcommands
      ;;

    args)
      case $words[1] in
        checkout)
          # Reuse git's own branch source — local + unique remote names
          local -a branches
          branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
          local -a remote_branches
          remote_branches=(${(f)"$(git branch -r --format='%(refname:short)' 2>/dev/null | sed 's|^[^/]*/||' | sort -u)"})
          branches+=($remote_branches)
          _values 'branch' $branches
          ;;
        pull)
          # pull takes no additional arguments in git-moat
          ;;
        fetch)
          # First arg: remote name; subsequent args: flags or refspecs
          if (( CURRENT == 2 )); then
            local -a remotes
            remotes=(${(f)"$(git remote 2>/dev/null)"})
            local -a fetch_flags
            fetch_flags=(
              '--all[fetch from all remotes]'
              '--prune[remove stale remote-tracking refs]'
              '--tags[fetch all tags]'
              '--depth[deepen a shallow clone]:depth'
              '--unshallow[convert a shallow clone to a full one]'
              '--dry-run[show what would be fetched]'
              '(-v --verbose)'{-v,--verbose}'[be verbose]'
              '(-q --quiet)'{-q,--quiet}'[suppress output]'
            )
            _describe 'remote' remotes
            _arguments $fetch_flags
          elif (( CURRENT == 3 )); then
            # After remote: offer remote-tracking branches as refspecs
            local remote=$words[2]
            local -a refs
            refs=(${(f)"$(git ls-remote --heads "$remote" 2>/dev/null | awk '{print $2}' | sed 's|refs/heads/||')"})
            _values 'refspec' $refs
          fi
          ;;
        clone)
          # Pass through to git's own completion when available
          if (( $+functions[__git_complete_remote_or_refspec] )); then
            _git
          fi
          ;;
      esac
      ;;
  esac
}

_git-moat "$@"
